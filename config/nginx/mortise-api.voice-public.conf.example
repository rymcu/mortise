upstream mortise_backend {
    least_conn;
    server 127.0.0.1:9999 max_fails=3 fail_timeout=30s;
    keepalive 32;
}

limit_req_zone $binary_remote_addr zone=voice_write:10m rate=5r/s;
limit_req_zone $binary_remote_addr zone=voice_read:10m rate=20r/s;
limit_conn_zone $binary_remote_addr zone=per_ip:10m;

server {
    listen 80;
    server_name api.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name api.example.com;

    ssl_certificate /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/privkey.pem;
    ssl_session_timeout 5m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    client_max_body_size 20m;
    keepalive_timeout 65;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Request-Id $request_id;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;

    location = /api/v1/voice/asr/recognize-once {
        limit_except POST { deny all; }
        limit_req zone=voice_write burst=10 nodelay;
        limit_conn per_ip 20;
        proxy_request_buffering off;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
        rewrite ^ /mortise$uri break;
        proxy_pass http://mortise_backend;
    }

    location = /api/v1/voice/tts/synthesize {
        limit_except POST { deny all; }
        limit_req zone=voice_write burst=10 nodelay;
        limit_conn per_ip 20;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
        rewrite ^ /mortise$uri break;
        proxy_pass http://mortise_backend;
    }

    location ^~ /api/v1/voice/jobs {
        limit_except GET { deny all; }
        limit_req zone=voice_read burst=30 nodelay;
        limit_conn per_ip 40;
        proxy_read_timeout 30s;
        rewrite ^ /mortise$uri break;
        proxy_pass http://mortise_backend;
    }

    location = /mortise/actuator/health {
        access_log off;
        allow 127.0.0.1;
        allow 10.0.0.0/8;
        deny all;
        proxy_read_timeout 10s;
        proxy_pass http://mortise_backend/mortise/actuator/health;
    }

    location ^~ /api/ {
        limit_conn per_ip 60;
        proxy_read_timeout 60s;
        rewrite ^ /mortise$uri break;
        proxy_pass http://mortise_backend;
    }
}
