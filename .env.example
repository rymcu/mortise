# ================================================================
#  Mortise 环境变量配置
#  用途: Docker Compose 基础设施 + Spring Boot 应用（共享同一套变量）
#  使用: cp .env.example .env && 修改所有 changeme 值
# ================================================================

# ==================== Database (Compose + Spring Boot) ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_SCHEMA=mortise
POSTGRES_USER=mortise
POSTGRES_PASSWORD=changeme

# ==================== Redis (Compose + Spring Boot) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DATABASE=1

# ==================== General ====================
TZ=Asia/Shanghai
# Jasypt 加密主密钥，Spring Boot 通过 System.getenv("ENCRYPTION_KEY") 读取
ENCRYPTION_KEY=changeme

# ==================== Spring Boot 应用 ====================
SERVER_PORT=9999
BASE_URL=https://rymcu.local
JWT_SECRET=changeme
GITHUB_TOKEN=

# ==================== 邮件 (Spring Boot) ====================
MAIL_HOST=smtp.larksuite.com
MAIL_PORT=465
MAIL_PERSON=ATDAK
MAIL_USERNAME=services@atdak.com
MAIL_PASSWORD=changeme

# ==================== Logto (Compose) ====================
LOGTO_DB_NAME=logto
LOGTO_ENDPOINT=https://auth.rymcu.local
LOGTO_ADMIN_ENDPOINT=https://logto.rymcu.local
LOGTO_INTEGRATION_TEST=true
LOGTO_TRUST_PROXY_HEADER=true
LOGTO_AUTH_HOST=auth.rymcu.local
LOGTO_ADMIN_HOST=logto.rymcu.local
# 宿主机 IP，供 Logto 容器通过 extra_hosts 解析域名
LOGTO_HOST_IP=172.17.0.1
LOGTO_PORT=3001
LOGTO_ADMIN_PORT=3002

# ==================== S3 兼容对象存储 (Compose + Spring Boot) ====================
# 变量名保留 RUSTFS_* 兼容现有 application-prod.yml，
# 生产环境可直接指向兼容 S3 的对象存储或兼容网关。
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_BUCKET=mortise
# ── 以下变量供 Spring Boot 生产环境使用（application-prod.yml） ──
RUSTFS_ENDPOINT=http://mortise-rustfs:9000
RUSTFS_DOMAIN=http://localhost:9000/mortise/
RUSTFS_BASE_PATH=public/

# ==================== Voice Runtime (Spring Boot 生产环境) ====================
VOICE_RUNTIME_NODE_ID=voice-runtime-prod-01
VOICE_RUNTIME_BASE_URL=http://voice-runtime.internal
VOICE_RUNTIME_ENABLED=true
VOICE_RUNTIME_CONNECT_TIMEOUT_MILLIS=1500
VOICE_RUNTIME_READ_TIMEOUT_MILLIS=30000
VOICE_RUNTIME_PREWARM_MODEL_1=sense-voice-zh-en-ja-ko-yue-int8

# ==================== Nginx (Compose) ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== EMQX MQTT Broker（AIoT 可选，compose --profile aiot 启用）====================
EMQX_MQTT_PORT=1883
EMQX_MQTTS_PORT=8883
EMQX_WS_PORT=8083
EMQX_WSS_PORT=8084
EMQX_DASHBOARD_PORT=18083
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=changeme

# ==================== 后端 / 前端地址（Nginx upstream 使用）====================
BACKEND_HOST=192.168.1.190
BACKEND_PORT=9999
FRONTEND_HOST=192.168.1.190
FRONTEND_PORT=3000
